# Placeholder for runner local configuration
RUNNER_ENV=development
API_BASE_URL=http://localhost:3001
AUTH_COOKIE_NAME=sup_session
DATABASE_URL=postgresql://synthetic_user:synthetic_password@localhost:5432/synthetic_user_platform
REDIS_URL=redis://localhost:6379

# Auth for posting events and account reservation APIs
RUNNER_API_EMAIL=admin@syntheticlabs.local
RUNNER_API_PASSWORD=ChangeMe123!

# Agent execution
RUN_ID=
RUNNER_HEADLESS=true
RUNNER_SLOW_MO_MS=0
RUNNER_NAV_TIMEOUT_MS=20000
RUNNER_DEFAULT_PASSWORD=Password123!
TEST_ACCOUNT_ENCRYPTION_KEY=replace-with-a-long-random-secret-at-least-32-characters

# Login selectors for default scripted workflow
RUNNER_LOGIN_USERNAME_SELECTOR=input[name="username"], input[type="email"], #username
RUNNER_LOGIN_PASSWORD_SELECTOR=input[name="password"], #password
RUNNER_LOGIN_SUBMIT_SELECTOR=button[type="submit"], input[type="submit"]

# Optional explicit workflow actions as JSON array (demo override)
RUNNER_SCRIPT_JSON=
