                         "zod":  "^4.1.12",
                         "@synthetic/shared":  "0.1.0"
                     },
    "devDependencies":  {
                            "@types/cookie-parser":  "^1.4.10",
                            "@types/express":  "^5.0.3",
                            "@types/jsonwebtoken":  "^9.0.10",
