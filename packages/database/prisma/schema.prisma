generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  TESTER
  VIEWER
}

enum EnvironmentType {
  LOCAL
  STAGING
  DEMO
}

enum EnvironmentStatus {
  ACTIVE
  INACTIVE
  UNREACHABLE
}

enum TestAccountStatus {
  AVAILABLE
  RESERVED
  DISABLED
}

enum WorkflowType {
  SCRIPTED
  GOAL_BASED
  EXPLORATORY
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELED
}

enum AgentStatus {
  IDLE
  RUNNING
  COMPLETED
  FAILED
}

enum EventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ArtifactType {
  SCREENSHOT
  TRACE
  VIDEO
  CONSOLE_LOG
  NETWORK_LOG
  REPORT
}

enum FindingType {
  UX_FRICTION
  BUG
  PERFORMANCE_ISSUE
  ACCESSIBILITY_CONCERN
  WORKFLOW_FAILURE
  SECURITY_CONCERN
  DATA_VALIDATION_ISSUE
  CONFUSING_COPY
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Organization {
  id                 String                  @id @default(uuid())
  name               String
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  users              User[]
  projects           Project[]
  environments       Environment[]
  personas           Persona[]
  workflows          Workflow[]
  testAccounts       TestAccount[]
  simulationRuns     SimulationRun[]
  simulationEvents   SimulationEvent[]
  llmUsages          LlmUsage[]
  llmProviderConfigs LlmProviderConfig[]
  budgetPolicies     BudgetPolicy[]
  actualMetricsImports ActualMetricsImport[]
  actualWorkflowMetrics ActualWorkflowMetric[]
  predictionAccuracies PredictionAccuracy[]
}

model User {
  id             String          @id @default(uuid())
  organizationId String
  email          String          @unique
  name           String
  role           UserRole
  passwordHash   String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulationRuns SimulationRun[] @relation("RunCreator")
  actualMetricsImports ActualMetricsImport[] @relation("ActualMetricsImporter")
}

model Project {
  id             String          @id @default(uuid())
  organizationId String
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environments   Environment[]
  workflows      Workflow[]
  simulationRuns SimulationRun[]
  actualMetricsImports ActualMetricsImport[]
  actualWorkflowMetrics ActualWorkflowMetric[]
  predictionAccuracies PredictionAccuracy[]

  @@unique([organizationId, name])
}

model Environment {
  id             String            @id @default(uuid())
  organizationId String
  projectId      String
  name           String
  baseUrl        String
  type           EnvironmentType
  allowedDomains String[]          @default([])
  status         EnvironmentStatus @default(ACTIVE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  testAccounts   TestAccount[]
  simulationRuns SimulationRun[]
  actualMetricsImports ActualMetricsImport[]
  actualWorkflowMetrics ActualWorkflowMetric[]
  predictionAccuracies PredictionAccuracy[]

  @@unique([projectId, name])
}

model Persona {
  id                   String            @id @default(uuid())
  organizationId       String
  name                 String
  role                 String
  industry             String
  technicalProficiency Int
  domainExpertise      Int
  timePressure         Int
  patience             Int
  confidence           Int
  errorRecovery        Int
  riskTolerance        Int
  accessibilityNeeds   String[]          @default([])
  behaviorNotes        String            @default("")
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  organization         Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulationRuns       SimulationRun[]
  simulationAgents     SimulationAgent[]

  @@unique([organizationId, name])
}

model Workflow {
  id                 String          @id @default(uuid())
  organizationId     String
  projectId          String
  name               String
  description        String          @default("")
  goal               String
  startingPath       String
  maxSteps           Int
  maxDurationSeconds Int
  successCriteria    Json
  workflowType       WorkflowType
  status             WorkflowStatus  @default(DRAFT)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  simulationRuns     SimulationRun[]
  actualWorkflowMetrics ActualWorkflowMetric[]
  predictionAccuracies PredictionAccuracy[]

  @@unique([projectId, name])
}

model ActualMetricsImport {
  id             String               @id @default(uuid())
  organizationId String
  projectId      String
  environmentId  String
  importedByUserId String
  sourceType     String               @default("MANUAL_CSV")
  sourceLabel    String
  notes          String               @default("")
  periodStart    DateTime
  periodEnd      DateTime
  rowCount       Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment    Environment          @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  importedByUser User                 @relation("ActualMetricsImporter", fields: [importedByUserId], references: [id], onDelete: Cascade)
  workflowMetrics ActualWorkflowMetric[]
  predictionAccuracies PredictionAccuracy[]

  @@index([organizationId, createdAt])
  @@index([projectId, environmentId, createdAt])
}

model ActualWorkflowMetric {
  id                    String              @id @default(uuid())
  organizationId        String
  actualMetricsImportId String
  projectId             String
  environmentId         String
  workflowId            String
  taskSuccessRate       Decimal             @db.Decimal(7, 2)
  completionTimeMs      Int
  errorRate             Decimal             @db.Decimal(7, 2)
  apiCallsPerSession    Decimal             @db.Decimal(10, 2)
  supportTicketCount    Int
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actualMetricsImport   ActualMetricsImport @relation(fields: [actualMetricsImportId], references: [id], onDelete: Cascade)
  project               Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment           Environment         @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  workflow              Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  predictionAccuracies  PredictionAccuracy[]

  @@unique([actualMetricsImportId, workflowId])
  @@index([organizationId, projectId, environmentId])
}

model TestAccount {
  id                    String                 @id @default(uuid())
  organizationId        String
  environmentId         String
  label                 String
  username              String
  email                 String
  role                  String
  passwordSecretRef     String?
  encryptedPassword     String?
  allowConcurrentUse    Boolean                @default(false)
  status                TestAccountStatus      @default(AVAILABLE)
  notes                 String                 @default("")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  organization          Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  environment           Environment            @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  reservations          TestAccountReservation[]

  @@unique([environmentId, username])
  @@unique([environmentId, email])
}

model TestAccountReservation {
  id            String      @id @default(uuid())
  testAccountId String
  runId         String
  agentId       String
  createdAt     DateTime    @default(now())
  releasedAt    DateTime?
  testAccount   TestAccount @relation(fields: [testAccountId], references: [id], onDelete: Cascade)

  @@index([testAccountId, releasedAt])
}

model SimulationRun {
  id              String            @id @default(uuid())
  organizationId  String
  projectId       String
  environmentId   String
  workflowId      String
  budgetPolicyId  String?
  personaId       String?
  selectedPersonaIds String[]       @default([])
  selectedTestAccountIds String[]   @default([])
  requestedAgentCount Int
  maxRunDurationSeconds Int
  createdByUserId String
  status          RunStatus         @default(PENDING)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment     Environment       @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  workflow        Workflow          @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  budgetPolicy    BudgetPolicy?     @relation(fields: [budgetPolicyId], references: [id], onDelete: SetNull)
  persona         Persona?          @relation(fields: [personaId], references: [id], onDelete: SetNull)
  createdByUser   User              @relation("RunCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  agents          SimulationAgent[]
  events          SimulationEvent[]
  llmUsages       LlmUsage[]
  artifacts       Artifact[]
  findings        Finding[]
  predictionAccuracies PredictionAccuracy[]
}

model SimulationAgent {
  id              String          @id @default(uuid())
  simulationRunId String
  personaId       String?
  testAccountId   String?
  status          AgentStatus     @default(IDLE)
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  simulationRun   SimulationRun   @relation(fields: [simulationRunId], references: [id], onDelete: Cascade)
  persona         Persona?        @relation(fields: [personaId], references: [id], onDelete: SetNull)
  artifacts       Artifact[]
}

model SimulationEvent {
  id              String        @id @default(uuid())
  organizationId  String
  runId           String
  agentId         String?
  personaId       String?
  traceId         String?
  eventType       String
  severity        EventSeverity @default(INFO)
  payload         Json
  timestamp       DateTime      @default(now())
  createdAt       DateTime      @default(now())
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulationRun   SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, timestamp])
}

model Artifact {
  id                String          @id @default(uuid())
  simulationRunId   String
  simulationAgentId String
  type              ArtifactType
  uri               String
  createdAt         DateTime        @default(now())
  simulationRun     SimulationRun   @relation(fields: [simulationRunId], references: [id], onDelete: Cascade)
  simulationAgent   SimulationAgent @relation(fields: [simulationAgentId], references: [id], onDelete: Cascade)
}

model Finding {
  id               String          @id @default(uuid())
  simulationRunId  String
  type             FindingType
  title            String
  summary          String
  severity         FindingSeverity
  confidence       Decimal         @db.Decimal(5, 2)
  affectedPersonas String[]        @default([])
  affectedWorkflow String
  evidenceEventIds String[]        @default([])
  recommendation   String
  detail           String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  simulationRun    SimulationRun   @relation(fields: [simulationRunId], references: [id], onDelete: Cascade)
}

model PredictionAccuracy {
  id                    String              @id @default(uuid())
  organizationId        String
  actualMetricsImportId String
  actualWorkflowMetricId String
  simulationRunId       String?
  projectId             String
  environmentId         String
  workflowId            String
  syntheticTaskSuccessRate Decimal         @db.Decimal(7, 2)
  actualTaskSuccessRate Decimal            @db.Decimal(7, 2)
  taskSuccessGapPercent Decimal?           @db.Decimal(9, 2)
  syntheticCompletionTimeMs Int
  actualCompletionTimeMs Int
  completionTimeGapPercent Decimal?        @db.Decimal(9, 2)
  syntheticErrorRate    Decimal            @db.Decimal(7, 2)
  actualErrorRate       Decimal            @db.Decimal(7, 2)
  errorRateGapPercent   Decimal?           @db.Decimal(9, 2)
  syntheticApiCallsPerSession Decimal      @db.Decimal(10, 2)
  actualApiCallsPerSession Decimal         @db.Decimal(10, 2)
  apiCallsGapPercent    Decimal?           @db.Decimal(9, 2)
  syntheticSupportTicketEstimate Int
  actualSupportTicketCount Int
  supportTicketGapPercent Decimal?         @db.Decimal(9, 2)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actualMetricsImport   ActualMetricsImport @relation(fields: [actualMetricsImportId], references: [id], onDelete: Cascade)
  actualWorkflowMetric  ActualWorkflowMetric @relation(fields: [actualWorkflowMetricId], references: [id], onDelete: Cascade)
  simulationRun         SimulationRun?     @relation(fields: [simulationRunId], references: [id], onDelete: SetNull)
  project               Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment           Environment        @relation(fields: [environmentId], references: [id], onDelete: Cascade)
  workflow              Workflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([actualWorkflowMetricId, simulationRunId])
  @@index([organizationId, projectId, environmentId, workflowId])
}

model LlmProviderConfig {
  id             String        @id @default(uuid())
  organizationId String
  provider       String
  model          String
  encryptedApiKey String
  baseUrl        String?
  timeoutMs      Int?          @default(30000)
  status         String        @default("inactive")
  lastCheckedAt  DateTime?
  lastError      String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model BudgetPolicy {
  id                    String       @id @default(uuid())
  organizationId        String
  name                  String
  maxCostPerRun         Decimal?     @db.Decimal(12, 4)
  maxTokensPerRun       Int?
  maxActionsPerAgent    Int?
  maxDurationPerRunSeconds Int?
  maxDailyCost          Decimal?     @db.Decimal(12, 4)
  stopOnBudgetExceeded  Boolean      @default(true)
  isActive              Boolean      @default(true)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulationRuns        SimulationRun[]

  @@unique([organizationId, name])
}

model LlmUsage {
  id               String        @id @default(uuid())
  organizationId   String
  runId            String
  agentId          String?
  provider         String
  model            String
  inputTokens      Int
  outputTokens     Int
  totalTokens      Int
  estimatedCostUsd Decimal       @db.Decimal(12, 6)
  createdAt        DateTime      @default(now())
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  simulationRun    SimulationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@index([organizationId, createdAt])
}
