{
    "name":  "@synthetic/database",
    "version":  "0.1.0",
    "private":  false,
    "type":  "module",
    "main":  "src/index.ts",
    "types":  "src/index.ts",
    "scripts":  {
                    "build":  "tsc -p tsconfig.json",
                    "test":  "tsx --test src/repositories/*.test.ts",
                    "typecheck":  "tsc --noEmit -p tsconfig.json",
                    "prisma:generate":  "prisma generate",
                    "prisma:migrate":  "prisma migrate dev --name init",
                    "prisma:seed":  "tsx prisma/seed.ts"
                },
    "dependencies":  {
                         "@prisma/client":  "^6.8.2",
                         "bcryptjs":  "^3.0.2",
                         "@synthetic/shared":  "0.1.0"
                     },
    "devDependencies":  {
                            "prisma":  "^6.8.2",
                            "tsx":  "^4.20.6"
                        }
}
